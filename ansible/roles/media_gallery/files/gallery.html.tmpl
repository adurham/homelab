<!DOCTYPE html>
<!--
  Managed by Ansible — roles/media_gallery (rclone serve http --template).
  Custom Go html/template that renders the decrypted upstream source archive as a
  responsive dark-theme thumbnail grid instead of a plain file listing.
  Data model exposed by rclone: .Name .Title .Entries[] (.URL .Leaf .IsDir
  .Size .ModTime). Extension classification (image / video / other) is done
  client-side in JS to avoid relying on template string helpers. Self-
  contained: inline CSS + JS, no external dependencies.
-->
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <style>
    :root {
      --bg: #121316;
      --panel: #1c1e23;
      --panel-hi: #262a31;
      --fg: #e6e6e6;
      --muted: #8a909a;
      --accent: #4f9dff;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--fg);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }
    header {
      position: sticky;
      top: 0;
      z-index: 5;
      padding: 14px 20px;
      background: rgba(18, 19, 22, 0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid #2a2d34;
    }
    header h1 {
      margin: 0;
      font-size: 16px;
      font-weight: 600;
      word-break: break-all;
    }
    header .count { color: var(--muted); font-size: 13px; margin-top: 2px; }
    main { padding: 18px; }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 12px;
    }
    .tile {
      position: relative;
      display: block;
      aspect-ratio: 1 / 1;
      background: var(--panel);
      border: 1px solid #2a2d34;
      border-radius: 10px;
      overflow: hidden;
      text-decoration: none;
      color: var(--fg);
      transition: transform .12s ease, border-color .12s ease;
    }
    .tile:hover { transform: translateY(-2px); border-color: var(--accent); }
    .tile img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      background: #0c0d10;
    }
    .tile .label {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      padding: 6px 8px;
      font-size: 11px;
      line-height: 1.3;
      background: linear-gradient(to top, rgba(0,0,0,.82), rgba(0,0,0,0));
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .tile.dir, .tile.file, .tile.video {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 8px;
      padding: 10px;
      text-align: center;
    }
    .tile.dir { background: var(--panel-hi); }
    .glyph { font-size: 40px; line-height: 1; }
    .tile .name {
      font-size: 12px;
      color: var(--fg);
      word-break: break-word;
      max-height: 3.2em;
      overflow: hidden;
    }
    .video .play {
      position: absolute;
      top: 8px; right: 8px;
      font-size: 18px;
      background: rgba(0,0,0,.55);
      border-radius: 50%;
      width: 30px; height: 30px;
      display: flex; align-items: center; justify-content: center;
    }
    .empty { color: var(--muted); padding: 40px; text-align: center; }
    a { color: var(--accent); }
  </style>
</head>
<body>
  <header>
    <h1>{{ .Title }}</h1>
    <div class="count" id="count"></div>
  </header>
  <main>
    <div class="grid" id="grid">
    {{ range $i, $e := .Entries }}
      <a class="tile js-entry"
         href="{{ $e.URL }}"
         data-leaf="{{ $e.Leaf }}"
         data-url="{{ $e.URL }}"
         data-isdir="{{ if $e.IsDir }}1{{ else }}0{{ end }}">
        <span class="leaf-text" style="display:none">{{ $e.Leaf }}</span>
      </a>
    {{ end }}
    </div>
    <div class="empty" id="empty" style="display:none">This folder is empty.</div>
  </main>

  <script>
    (function () {
      var imageExt = ["jpg", "jpeg", "png", "webp", "gif", "bmp", "svg"];
      var videoExt = ["mp4", "mov", "webm", "mkv", "avi", "m4v"];

      function ext(name) {
        var n = name.toLowerCase().replace(/\/+$/, "");
        var dot = n.lastIndexOf(".");
        return dot >= 0 ? n.slice(dot + 1) : "";
      }

      var tiles = document.querySelectorAll(".js-entry");
      var n = 0;
      tiles.forEach(function (t) {
        n++;
        var leaf = t.getAttribute("data-leaf") || "";
        var url = t.getAttribute("data-url") || "";
        var isDir = t.getAttribute("data-isdir") === "1";
        t.innerHTML = "";

        if (isDir) {
          t.classList.add("dir");
          t.innerHTML =
            '<span class="glyph">\uD83D\uDCC1</span>' +
            '<span class="name"></span>';
          t.querySelector(".name").textContent = leaf.replace(/\/+$/, "");
          return;
        }

        var e = ext(leaf);
        if (imageExt.indexOf(e) !== -1) {
          var img = document.createElement("img");
          img.loading = "lazy";
          img.src = url;
          img.alt = leaf;
          t.appendChild(img);
          var lbl = document.createElement("span");
          lbl.className = "label";
          lbl.textContent = leaf;
          t.appendChild(lbl);
          // Open full-size image in a new tab.
          t.setAttribute("target", "_blank");
          t.setAttribute("rel", "noopener");
        } else if (videoExt.indexOf(e) !== -1) {
          t.classList.add("video");
          t.innerHTML =
            '<span class="play">\u25B6</span>' +
            '<span class="glyph">\uD83C\uDFAC</span>' +
            '<span class="name"></span>';
          t.querySelector(".name").textContent = leaf;
          t.setAttribute("target", "_blank");
          t.setAttribute("rel", "noopener");
        } else {
          t.classList.add("file");
          t.innerHTML =
            '<span class="glyph">\uD83D\uDCC4</span>' +
            '<span class="name"></span>';
          t.querySelector(".name").textContent = leaf;
        }
      });

      document.getElementById("count").textContent = n + " item" + (n === 1 ? "" : "s");
      if (n === 0) {
        document.getElementById("grid").style.display = "none";
        document.getElementById("empty").style.display = "block";
      }
    })();
  </script>
</body>
</html>
