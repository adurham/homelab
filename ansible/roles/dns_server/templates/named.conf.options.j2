acl "trusted" {
        127.0.0.0/8;
        ::1;              # IPv6 loopback — needed for `dig @localhost` from dns-01 itself
        {{ net_lan_range }};  # LAN
        {{ net_private_range }};    # Private SDN
        100.64.0.0/10;    # Tailscale (just in case)
};

tls local-tls {
    key-file "/etc/bind/ssl/key.pem";
    cert-file "/etc/bind/ssl/fullchain.pem";
};

options {
        directory "/var/cache/bind";

        recursion yes;
        allow-query { trusted; };

        # Upstream resolution via AdGuard Home on the homeassistant host.
        # AdGuard already does DoT upstream to Cloudflare; forwarding to
        # it gives us encrypted egress + the ad-block lists, and avoids
        # running a duplicate DoT proxy (stubby) on dns-01.
        # bind ↔ AdGuard is plaintext-on-LAN — accepted, since the
        # encrypted boundary is at the WAN egress.
        # forward-only fails closed if AdGuard is down: lab DNS breaks
        # but no plaintext fallback to public root resolvers.
        forwarders {
                {{ ip_homeassistant }};
        };
        forward only;

        # Don't fingerprint bind by version string. Default behavior is to
        # respond with the full build string for `version.bind` / `hostname.bind`
        # CHAOS-class TXT queries; this makes bind respond with "none" instead.
        version "none";
        hostname "none";

        dnssec-validation auto;
        listen-on { any; };
        listen-on-v6 { any; };

        # DoT Listener (server-side — accepts encrypted queries from clients)
        listen-on port 853 tls local-tls { any; };
        listen-on-v6 port 853 tls local-tls { any; };
};
