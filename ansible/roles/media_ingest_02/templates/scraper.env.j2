# Managed by Ansible — roles/media_ingest_02. Do not edit by hand.
# Secrets come from the vault; non-secret paths/URLs from role defaults.
#
# The scraper reads its own auth.json for upstream source credentials.
# The scraper resolves auth.json at get_config_path().parent / <main_profile> /
# authFile — i.e. <state>/main_profile/auth.json (main_profile is set in
# config.json). One-time assisted login writes it there; not committed.
# The gallery push path uses the same OAuth2 client_credentials flow as
# the primary collector.
M02_STAGING={{ media_ingest_02_state }}/staging
M02_LOG_FILE={{ media_ingest_02_log_dir }}/scraper.log
M02_AUTH_FILE={{ media_ingest_02_state }}/main_profile/auth.json
M02_CONFIG_FILE={{ media_ingest_02_state }}/config.json
M02_METADATA_DIR={{ media_ingest_02_state }}/metadata
# Upstream package identity (pip name + console-script binary name). SENSITIVE —
# the package name identifies the source platform, so it lives in the vault
# (vault_media_ingest_02_scraper_pkg / vault_media_ingest_02_scraper_bin) rather
# than in the repo. The wrapper invokes the binary by this name from the venv.
M02_SCRAPER_PKG={{ vault_media_ingest_02_scraper_pkg }}
M02_SCRAPER_BIN={{ vault_media_ingest_02_scraper_bin }}
# Which upstream models to scrape (comma-separated, passed to the scraper's
# --username flag). SENSITIVE — comes from the vault so names aren't in the repo.
M02_SCRAPE_USERNAMES={{ vault_media_ingest_02_scrape_usernames }}
# Optional second pass: auto-discover models matching a filter (e.g. active
# paid subs via "--current-price paid --active-subscription --username ALL").
# Space-separated scraper flags; empty = skip the auto-discovery pass. SENSITIVE
# — reveals the operator's subscription behavior, so it comes from the vault.
M02_SCRAPE_FILTER_ARGS={{ vault_media_ingest_02_scrape_filter_args }}
# Bounded per-sweep work: most-recent N posts per model. 0 = unbounded (full scan).
M02_SCRAPE_LOOKBACK={{ media_ingest_02_scrape_lookback }}
# Gallery push auth (same pattern as the primary collector — reuses the primary
# collector's OAuth2 client, see defaults/main.yml for rationale).
AUTHENTIK_TOKEN_URL={{ media_ingest_02_authentik_token_url }}
COLLECTOR_CLIENT_ID={{ media_ingest_02_collector_client_id }}
COLLECTOR_CLIENT_SECRET={{ vault_media_ingest_collector_client_secret }}
GALLERY_BASE={{ media_ingest_02_gallery_base }}
