apiVersion: 1
policies:
  - orgId: 1
    receiver: homeassistant
    group_by:
      - alertname
      - instance
    group_wait: 30s
    group_interval: 5m
    repeat_interval: 4h
    routes:
{% if healthchecks_dms_ping_url is defined and healthchecks_dms_ping_url %}
      # Dead-man's-switch route. The `dms = "true"` matcher catches only
      # the always-firing `dead_mans_switch` rule and routes ONLY to
      # healthchecks.io — `continue: false` prevents fanout to HA/email,
      # which would mean a notification every 5m on those channels.
      # repeat_interval = 5m gives healthchecks (period=5m) a fresh ping
      # before the grace window expires.
      - receiver: healthchecks_dms
        matchers:
          - dms = "true"
        group_wait: 0s
        group_interval: 5m
        repeat_interval: 5m
        continue: false
{% endif %}
      # Mirror every alert to the email fallback. Dual-fanout (continue: true)
      # so it doesn't replace the HA webhook -- both fire. Repeat interval
      # is longer here so the inbox doesn't get hammered if an alert is
      # stuck firing.
      - receiver: email
        continue: true
        group_wait: 30s
        group_interval: 5m
        repeat_interval: 12h
