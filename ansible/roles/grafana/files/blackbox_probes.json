{
  "annotations": {"list": []},
  "description": "blackbox_exporter probe status for Tanium postgres, Tanium server consoles, and HTTPS endpoints — plus TLS cert expiry runway.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"color": "red", "index": 0, "text": "DOWN"}, "1": {"color": "green", "index": 1, "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_success{job=\"blackbox_tanium_postgres\"}",
          "legendFormat": "{{instance}} pg ({{tanium_role}})",
          "refId": "A"
        }
      ],
      "title": "Tanium postgres TCP probes",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"color": "red", "index": 0, "text": "DOWN"}, "1": {"color": "green", "index": 1, "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_success{job=\"blackbox_tanium_console\"}",
          "legendFormat": "{{instance}} console",
          "refId": "A"
        }
      ],
      "title": "Tanium server console probes (:443)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"color": "red", "index": 0, "text": "DOWN"}, "1": {"color": "green", "index": 1, "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 6},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_success{job=\"blackbox_https_cert\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "HTTPS endpoint reachability",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 14}, {"color": "green", "value": 30}]},
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 6},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox_https_cert\"} - time()) / 86400",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "TLS cert days remaining",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 5,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "victoriametrics"},
          "expr": "probe_duration_seconds",
          "legendFormat": "{{job}} {{instance}}",
          "refId": "A"
        }
      ],
      "title": "Probe duration (seconds)",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["blackbox", "monitoring", "homelab"],
