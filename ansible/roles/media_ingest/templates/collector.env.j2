# Managed by Ansible — roles/media_ingest. Do not edit by hand.
# Secrets come from the vault; non-secret paths/URLs from role defaults.
TG_API_ID={{ vault_media_gallery_api_id }}
TG_API_HASH={{ vault_media_gallery_api_hash }}
TG_SESSION={{ media_ingest_state }}/collector
TG_STAGING={{ media_ingest_state }}/staging
TG_LOG_FILE={{ media_ingest_log_dir }}/collector.log
TG_BACKFILL_STATE={{ media_ingest_state }}/backfill_state.json
# Active-pull backstop interval (s): force getState+getDifference this often so
# self-destruct/TTL media isn't lost to Telegram's multi-minute push lag to the
# idle secondary session. 0 disables (pure passive push). See collector.py.
TG_POLL_INTERVAL=5
AUTHENTIK_TOKEN_URL={{ media_ingest_authentik_token_url }}
COLLECTOR_CLIENT_ID={{ media_ingest_collector_client_id }}
COLLECTOR_CLIENT_SECRET={{ vault_media_ingest_collector_client_secret }}
GALLERY_BASE={{ media_ingest_gallery_base }}
