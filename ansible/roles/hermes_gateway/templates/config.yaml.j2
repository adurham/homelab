# Managed by Ansible — do not edit by hand.
# Source: roles/hermes_gateway/templates/config.yaml.j2
#
# Mirrors the personal-MacBook config (provider=anthropic, memory features
# from the post-2026-05-09 pull, auxiliary providers routed through the
# Claude Code OAuth path). Local-LLM aux endpoints are intentionally
# omitted — this VM has no exo/LM-Studio reachability.
---
model:
  default: claude-opus-4-7
  provider: anthropic

agent:
  max_turns: 90
  gateway_timeout: 1800
  restart_drain_timeout: 60
  api_max_retries: 3
  service_tier: ''
  tool_use_enforcement: auto
  gateway_timeout_warning: 900
  gateway_notify_interval: 600
  gateway_auto_continue_freshness: 3600
  reasoning_effort: high
  interleaved_thinking: true
  # Move hermes's app system prompt into the first user message to keep
  # `system` matching real Claude Code's shape. Anthropic's billing
  # classifier on personal Max plans rejects requests with a non-CC-shaped
  # system prompt — without this every gateway turn 400s with "out of
  # extra usage". Behavior unchanged; placement only.
  system_prompt_mode: compact

# Anthropic server-side tool_search. Mirrors real Claude Code's deferred-tool
# pattern: the eager tool set (read/write/patch/search/terminal/todo/clarify
# /discord) ships full schemas in every request, while everything else is
# deferred — only its name + ``defer_loading: true`` flag is sent. The model
# discovers deferred tools on demand by calling ``tool_search`` with a regex.
#
# Why this matters here: Anthropic's billing classifier on personal Max plans
# rejects payloads with too much non-Claude-Code-shaped content (system prompt
# bytes, tool-def bytes, etc.) by routing them to extra-usage billing — which
# 400s on a Max plan that has no extra-usage budget. Compact mode + lazy
# skills already drop the system prompt under the threshold; tool_search does
# the same for tools, raising the practical tool count from ~13 to "as many
# as you want" while keeping the eager-schema budget around 10K bytes.
tool_search:
  enabled: true
  variant: regex
  defer_mcp_tools: true
  # Eager set: high-frequency coding core that the bot reaches for every
  # turn. Mirrors Claude Code's eager set (Bash/Read/Write/Edit/Grep/
  # TodoWrite/Task) — adapted to hermes tool names. ``discord`` stays
  # eager because the bot literally needs it to reply.
  additional_eager:
    - terminal
    - read_file
    - write_file
    - patch
    - search_files
    - todo
    - clarify
    - discord
  # Deferred set: everything else. Hydrated via the ``tool_search`` server
  # tool when the model needs it. ~50 bytes each instead of 1-3KB, so we
  # can ship a much larger toolset without busting the classifier ceiling.
  additional_deferred:
    - web_search
    - web_extract
    - vision_analyze
    - image_generate
    - skills_list
    - skill_view
    - skill_manage
    - memory
    - session_search
    - process
    - delegate_task
    - swarm_run
    - execute_code
    - discord_admin
    - text_to_speech

# Subagent (delegate_task / swarm_run) defaults. Mirrors Claude Code's
# Task tool behavior — orchestrator-style delegation with high reasoning
# inherited from the parent.
delegation:
  reasoning_effort: high
  # Two-level delegation: orchestrator can spawn leaf subagents but those
  # leaves can't spawn their own subagents. Matches Claude Code's
  # Plan → leaf-research-agent flow without runaway recursion.
  max_spawn_depth: 2
  max_concurrent_children: 3
  child_timeout_seconds: 600
  # Auto-approve dangerous-cmd prompts inside subagents. The Discord bot
  # has no human-in-the-loop UI to resolve approvals, so the choice is
  # auto-deny (children silently skip the cmd) or auto-approve (children
  # run it). Bot operates in cloned repos via gh PR workflow — worst case
  # is a bad commit on a feature branch you'd reject in review anyway.
  subagent_auto_approve: true

auxiliary:
  vision:
    provider: auto
    model: ''
    timeout: 120
    extra_body: {}
    download_timeout: 30
  web_extract:
    provider: auto
    model: ''
    timeout: 360
    extra_body: {}
  compression:
    provider: auto
    model: claude-sonnet-4-6
    timeout: 120
    extra_body: {}
  session_search:
    provider: auto
    model: claude-haiku-4-5
    timeout: 30
    extra_body: {}
    max_concurrency: 3
  skills_hub:
    provider: auto
    model: claude-haiku-4-5
    timeout: 30
    extra_body: {}
  memory_extraction:
    provider: auto
    model: claude-haiku-4-5
    timeout: 30
    extra_body: {}
    # Phase 2 controls — only consumed by tools/memory_extraction
    max_tokens_per_turn: 1024
    max_tokens_session_end: 2048
    include_pre_compress: true
    auto_commit_session_end: false
  approval:
    provider: auto
    model: ''
    timeout: 30
    extra_body: {}
  mcp:
    provider: auto
    model: ''
    timeout: 30
    extra_body: {}
  title_generation:
    provider: auto
    model: ''
    timeout: 30
    extra_body: {}
  curator:
    provider: auto
    model: ''
    timeout: 600
    extra_body: {}

memory:
  memory_enabled: true
  user_profile_enabled: true
  memory_char_limit: 4500
  user_char_limit: 5200
  provider: ''
  nudge_interval: 10
  flush_min_turns: 6
  # Phase 2 auto-extraction: watch turns + compression + session-end and
  # propose new warm-tier entries via Haiku. The CLI confirm prompt is N/A
  # on a headless gateway; auto_commit_session_end stays false (above) so
  # extracted entries land in proposals only, never silently committed.
  auto_extract: true

skills:
  # Skip the bulky <available_skills> index in the system prompt; the model
  # discovers skills on demand via the skills_list tool. Without this, the
  # full skill catalogue (~9K chars / 5K tokens for ~148 skills) lands in
  # the system prompt, and Anthropic's billing classifier on the personal
  # Max plan rejects the resulting payload as "non-Claude-Code" — every
  # gateway request 400s with "out of extra usage". Lazy-loading drops the
  # system prompt below the classifier threshold; same just-in-time pattern
  # tool_search uses for tools.
  lazy_listing: true

# Per-platform toolset overrides. With ``tool_search.enabled: true`` (above)
# the count-of-tools is no longer the bottleneck — only the eager set's
# combined schema bytes count toward the classifier ceiling, and that's
# tightly controlled by ``tool_search.additional_eager``. So Discord gets
# the full coding-agent capability surface here; the heavy ones get
# deferred via tool_search rather than being chopped from the toolset.
#
# Mirrors Claude Code's CLI feel: the bot can run shells, edit files,
# search code, spawn subagents, browse, search the web, generate images,
# look at attachments, manage skills/memory/sessions. ``tts`` intentionally
# dropped — useless in DM workflow.
platform_toolsets:
  discord:
    - web              # web_search, web_extract
    - vision           # vision_analyze
    - image_gen        # image_generate
    - file             # read_file, write_file, patch, search_files
    - terminal         # terminal, process
    - code_execution   # execute_code (sandboxed)
    - delegation       # delegate_task, swarm_run (subagent spawning)
    - skills           # skills_list, skill_view, skill_manage
    - memory           # memory tool
    - session_search   # search past sessions
    - todo             # task list
    - clarify          # ask user a question
    - discord          # built-in: react/embed/etc.
    - discord_admin    # built-in: admin actions
