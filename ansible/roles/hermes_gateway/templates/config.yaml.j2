# Managed by Ansible — do not edit by hand.
# Source: roles/hermes_gateway/templates/config.yaml.j2
#
# ALL-LOCAL exo setup (2026-06-11): the gateway runs entirely on the local
# exo cluster reachable at 192.168.86.201:52415 (verified from this LXC:
# ping + /v1/models 200 + live DSv4/Qwen3.6 generation). No cloud provider.
#   - main reasoning thread  -> DeepSeek-V4-Flash (provider: exo)
#   - delegate_task subagents -> Qwen3.6 (delegation.model below)
#   - all auxiliary tasks incl. vision/image -> Qwen3.6 (custom:exo)
---
model:
  default: mlx-community/DeepSeek-V4-Flash
  provider: exo

# Local exo cluster (Thunderbolt-direct Mac Studios). Mirrors the
# MacBook/Studio config block. discover_models off — models enumerated
# explicitly so the gateway never probes the cluster's full catalog.
providers:
  exo:
    base_url: http://192.168.86.201:52415/v1
    api_key: not-needed
    api_mode: chat_completions
    discover_models: false
    models:
      mlx-community/DeepSeek-V4-Flash:
        context_length: 1048576
      mlx-community/Qwen3.6-35B-A3B-8bit:
        context_length: 262144
    extra_body:
      use_prefix_cache: true

# Web search for the all-local (exo/DSv4) gateway. brave-free is the
# primary backend (BRAVE_SEARCH_API_KEY in env); ddgs (keyless DuckDuckGo)
# is the auto-detect fallback. anthropic_native_search stays true so that
# IF this gateway is ever switched back to a Claude main provider it uses
# Anthropic's native server-side search — non-Claude providers (exo/DSv4)
# always use the client web_search tool with search_backend below.
web:
  backend: ''
  search_backend: brave-free
  extract_backend: ''
  anthropic_native_search: true
  anthropic_native_search_max_uses: 5

agent:
  max_turns: 90
  gateway_timeout: 1800
  restart_drain_timeout: 60
  api_max_retries: 3
  service_tier: ''
  tool_use_enforcement: auto
  gateway_timeout_warning: 900
  gateway_notify_interval: 600
  gateway_auto_continue_freshness: 3600
  reasoning_effort: high
  interleaved_thinking: true
  # Move hermes's app system prompt into the first user message to keep
  # `system` matching real Claude Code's shape. Anthropic's billing
  # classifier on personal Max plans rejects requests with a non-CC-shaped
  # system prompt — without this every gateway turn 400s with "out of
  # extra usage". Behavior unchanged; placement only.
  system_prompt_mode: compact

# Anthropic server-side tool_search. With the CC-mimicry layer in
# place (canonical CC tool names + x-anthropic-billing-header system
# block, both in agent/anthropic_adapter.py) AND hermes-agent's
# patched _apply_tool_search that strips description+input_schema
# from deferred entries, this gives us the full benefit:
#
#   * Eager tools (additional_eager) ship full schemas — these are
#     the high-frequency coding core.
#   * Deferred tools (additional_deferred) ship as ~120-byte stubs
#     of {name, description: "", input_schema: {type: object},
#     defer_loading: true}.
#   * Anthropic's classifier accepts the canonical-CC-shaped request
#     regardless of total payload size, so we can carry an
#     arbitrarily wide toolset without 400s.
#   * The model summons a deferred tool's full schema by calling
#     tool_search_tool_regex (one extra round-trip on first use per
#     session), then uses it normally.
# NESTED tools.tool_search — read by tools/tool_search.py load_config(),
# which drives the UNIVERSAL assemble_tool_defs (ALL providers incl. exo),
# distinct from the top-level tool_search: block below (anthropic path only).
# hermes-agent's DEFAULT_CONFIG seeds this nested key to "auto", and at
# DSv4's 1,048,576-token context the 10%-of-context auto threshold (~105K)
# sits ABOVE the ~85K MCP catalog, so deferral silently NEVER fires and every
# turn ships the full tool catalog (~100K-token prefix, ~minutes of prefill).
# Pin "on" so MCP-tool deferral activates unconditionally. (Quote the value:
# bare `on` is YAML bool True.)
tools:
  tool_search:
    enabled: "on"
    threshold_pct: 10
    search_default_limit: 5
    max_search_limit: 20

tool_search:
  enabled: true
  variant: regex
  defer_mcp_tools: true
  # Eager set: high-frequency tools that ship every turn. Mirrors
  # what real Claude Code keeps eager (Bash/Read/Edit/Write/Grep
  # /TodoWrite). Outbound substitution to canonical CC names happens
  # in agent/cc_aliases.replace_with_cc_canonical.
  additional_eager:
    - terminal
    - read_file
    - write_file
    - patch
    - search_files
    - todo
  # Deferred set: name-only stubs. The model knows these tools exist
  # by name but has to tool_search before using them. Add freely;
  # extra entries are ~120 bytes each.
  additional_deferred:
    - process
    - clarify
    - vision_analyze
    - image_generate
    - web_search
    - web_extract
    - skills_list
    - skill_view
    - skill_manage
    - memory
    - session_search
    - delegate_task
    - swarm_run
    - execute_code
    - ha_list_entities
    - ha_get_state
    - ha_list_services
    - ha_call_service
    - text_to_speech

# Subagent (delegate_task / swarm_run) defaults. Mirrors Claude Code's
# Task tool behavior — orchestrator-style delegation with high reasoning
# inherited from the parent.
delegation:
  reasoning_effort: high
  # Route delegate_task / swarm_run subagents to Qwen3.6 on the local exo
  # cluster (the lighter model), keeping the DSv4 main thread free for the
  # orchestrator. Resolution order is arg > delegation.model > parent model.
  provider: exo
  model: mlx-community/Qwen3.6-35B-A3B-8bit
  # Two-level delegation: orchestrator can spawn leaf subagents but those
  # leaves can't spawn their own subagents. Matches Claude Code's
  # Plan → leaf-research-agent flow without runaway recursion.
  max_spawn_depth: 2
  max_concurrent_children: 3
  child_timeout_seconds: 600
  # Auto-approve dangerous-cmd prompts inside subagents. The Discord bot
  # has no human-in-the-loop UI to resolve approvals, so the choice is
  # auto-deny (children silently skip the cmd) or auto-approve (children
  # run it). Bot operates in cloned repos via gh PR workflow — worst case
  # is a bad commit on a feature branch you'd reject in review anyway.
  subagent_auto_approve: true

auxiliary:
  # Vision/image analysis -> Qwen3.6 on the local exo cluster. DSv4 can't
  # see pixels, so images attached to the main thread are delegated here
  # (text description fed back to DSv4). Explicit endpoint mirrors the
  # MacBook/Studio vision config.
  vision:
    provider: custom:exo
    model: mlx-community/Qwen3.6-35B-A3B-8bit
    base_url: http://192.168.86.201:52415/v1
    api_key: not-needed
    api_mode: chat_completions
    timeout: 120
    extra_body: {}
    download_timeout: 30
  web_extract:
    provider: auto
    model: ''
    timeout: 360
    extra_body: {}
  compression:
    provider: auto
    model: ''
    timeout: 120
    extra_body: {}
  session_search:
    provider: auto
    model: ''
    timeout: 30
    extra_body: {}
    max_concurrency: 3
  skills_hub:
    provider: auto
    model: ''
    timeout: 30
    extra_body: {}
  memory_extraction:
    provider: auto
    model: ''
    timeout: 30
    extra_body: {}
    # Phase 2 controls — only consumed by tools/memory_extraction
    max_tokens_per_turn: 1024
    max_tokens_session_end: 2048
    include_pre_compress: true
    # Auto-commit at session end. The gateway is headless so there's no
    # confirm UI to surface proposals — without this, every session-end
    # extraction stashes its facts back into the buffer and they never
    # reach the warm tier. With auto_commit on:
    #   - NEW facts auto-write
    #   - DUPLICATE bumps recall-count instead of writing a duplicate
    #   - REFINEMENT merges into the matched entry
    #   - CONTRADICTION still stays uncommitted (apply_verdict's inner
    #     auto_commit=False; the user resolves manually via memory tool)
    # So cross-session learnings accumulate; the only thing left for
    # human review is genuinely conflicting facts.
    auto_commit_session_end: true
  approval:
    provider: auto
    model: ''
    timeout: 30
    extra_body: {}
  mcp:
    provider: auto
    model: ''
    timeout: 30
    extra_body: {}
  title_generation:
    provider: auto
    model: ''
    timeout: 30
    extra_body: {}
  curator:
    provider: auto
    model: ''
    timeout: 600
    extra_body: {}

memory:
  memory_enabled: true
  user_profile_enabled: true
  memory_char_limit: 4500
  user_char_limit: 5200
  provider: ''
  nudge_interval: 10
  flush_min_turns: 6
  # Phase 2 auto-extraction: watch turns + compression + session-end and
  # propose new warm-tier entries via Haiku. The CLI confirm prompt is N/A
  # on a headless gateway; auto_commit_session_end stays false (above) so
  # extracted entries land in proposals only, never silently committed.
  auto_extract: true

skills:
  # Skip the bulky <available_skills> index in the system prompt; the model
  # discovers skills on demand via the skills_list tool. Without this, the
  # full skill catalogue (~9K chars / 5K tokens for ~148 skills) lands in
  # the system prompt, and Anthropic's billing classifier on the personal
  # Max plan rejects the resulting payload as "non-Claude-Code" — every
  # gateway request 400s with "out of extra usage". Lazy-loading drops the
  # system prompt below the classifier threshold; same just-in-time pattern
  # tool_search uses for tools.
  lazy_listing: true

# Per-platform toolset overrides. Curated to fit under Anthropic's billing
# classifier ceiling on personal Max accounts via the OAuth path. Bisected
# empirically (using `hermes -z` with each toolset list and inspecting the
# resulting request_dump_*.json):
#
#   ~14K (web/vision/terminal/file/todo/clarify) — passes
#   ~15K (+ image_gen)                            — passes
#   ~17K (+ session_search)                       — fails: "out of extra usage"
#   ~22K (+ skills + session_search)              — fails: "out of extra usage"
#
# Per-tool sizes (live build):
#   terminal      4811   file          4926
#   todo          1340   clarify       1258
#   vision        937    web           797
#   homeassistant 2570 (4 ha_* tools, gated by HASS_TOKEN env)
#
# Current total: ~16.6K (web 797 + vision 937 + terminal 4811 + file 4926
# + todo 1340 + clarify 1258 + homeassistant 2570). Above the 15K-pass
# / 17K-fail edge — if requests start 400'ing on "out of extra usage",
# drop ``clarify`` (saves 1.3K, lands at ~15.3K) or ``vision`` (saves
# 0.9K, lands at ~15.7K).
platform_toolsets:
  # Wide toolset — capability surface for the bot. Heavy/rare tools
  # are picked up but ship as deferred stubs via tool_search above
  # (skills, memory, delegation, code_execution, image_gen,
  # session_search), so the eager wire payload stays small. Add
  # toolsets here freely; the deferred-list above keeps wire bytes
  # under control.
  discord:
    - web              # web_search + web_extract  (deferred)
    - vision           # vision_analyze            (deferred)
    - terminal         # terminal + process        (eager — aliased to CC's Bash on wire)
    - file             # read/write/patch/search_files (eager — Read/Write/Edit/Grep on wire)
    - todo             # task list                 (eager)
    - clarify          # ask user a question       (deferred)
    - homeassistant    # ha_list_entities/get_state/list_services/call_service (deferred)
    - skills           # skills_list / skill_view / skill_manage (deferred)
    - memory           # memory                    (deferred)
    - session_search   # session_search            (deferred)
    - delegation       # delegate_task / swarm_run (deferred — subagent spawning)
    - code_execution   # execute_code              (deferred — sandboxed)
    - image_gen        # image_generate            (deferred)
