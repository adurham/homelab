# Managed by Ansible — do not edit by hand.
# Source: roles/hermes_gateway/templates/env.j2

# Discord bot token — required for the Discord platform adapter to load.
DISCORD_BOT_TOKEN={{ vault_hermes_gw_discord_bot_token }}

# User allowlist — comma-separated Discord user IDs. Without this set, the
# gateway logs "No user allowlists configured" and rejects everyone (the bot
# stays online but ignores all messages). DM the bot from one of these IDs
# to interact; everyone else is silently dropped.
DISCORD_ALLOWED_USERS={{ vault_hermes_gw_discord_allowed_users }}

# Anthropic credentials are sourced from /home/hermes/.claude/.credentials.json
# (the same shape Claude Code itself uses on Linux). Leaving these empty
# forces hermes through that OAuth path rather than falling back to an API
# key. Mirrors the layout in use on the personal MacBook.
ANTHROPIC_API_KEY=
ANTHROPIC_TOKEN=
