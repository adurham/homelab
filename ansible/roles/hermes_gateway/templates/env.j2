# Discord bot token — required for the Discord platform adapter to load.
DISCORD_BOT_TOKEN={{ vault_hermes_gw_discord_bot_token }}

# User allowlist — comma-separated Discord user IDs. Without this set, the
# gateway logs "No user allowlists configured" and rejects everyone (the bot
# stays online but ignores all messages). DM the bot from one of these IDs
# to interact; everyone else is silently dropped.
DISCORD_ALLOWED_USERS={{ vault_hermes_gw_discord_allowed_users }}

# Anthropic credentials.
#
# CLAUDE_CODE_OAUTH_TOKEN is a long-lived (1-year) setup-token created
# via `claude setup-token` on this CT, vaulted alongside the rest of our
# secrets. It's the source of truth — hermes resolves it ahead of the
# /home/hermes/.claude/.credentials.json file (which the bootstrap task
# seeds for the first turn but never overwrites afterwards). Long-lived
# means there's no refresh-rotation chain that can drift between machines,
# so the LXC stays self-sufficient even when the laptop's keychain rotates.
#
# ANTHROPIC_API_KEY / ANTHROPIC_TOKEN intentionally empty so the OAuth path
# is the only one in play — matches the personal-MacBook layout.
CLAUDE_CODE_OAUTH_TOKEN={{ vault_hermes_gw_claude_code_oauth_token }}
ANTHROPIC_API_KEY=
ANTHROPIC_TOKEN=

# Strip the context-1m-2025-08-07 beta from any request whose body is
# smaller than this token threshold. Required on Claude Max subscriptions:
# the 1M-context tier bills against "extra usage" (a separate budget from
# the included plan), so without this, every gateway message — even a tiny
# "hi" — 400s with a misleading "out of extra usage" error. 180000 keeps us
# safely under the 200K standard-tier limit; the gateway never builds up
# cached prefixes large enough to need the 1M tier anyway.
HERMES_CONTEXT_1M_THRESHOLD_TOKENS=180000

# GitHub auth: SSH-based, not token-based. The hermes user has an
# ed25519 keypair at /home/hermes/.ssh/id_ed25519 (generated by
# repos.yml) and gh CLI auth set up via one-time `gh auth login` from
# an interactive shell on this CT. No long-lived secret lives here —
# git pushes use the SSH key, gh CLI ops use the gh-managed OAuth
# token in /home/hermes/.config/gh/hosts.yml.

# Home Assistant integration. HASS_TOKEN is a long-lived access token
# generated at http://192.168.86.2:8123/profile/security — gates the
# ha_* toolset (hermes registers ha_list_entities / ha_get_state /
# ha_list_services / ha_call_service only when both env vars are set).
# Rotate via the HA UI; vault entry must be updated in lockstep.
HASS_URL=http://{{ ip_homeassistant }}:8123
HASS_TOKEN={{ vault_hermes_gw_hass_token }}

# Gateway HTTP API for remote job submission from the laptop.
# Setting API_SERVER_KEY enables the api_server platform adapter
# (see gateway/config.py:1420 — `enabled or key set` is the trigger).
# Binding to the CT's private IP (not 127.0.0.1) so the laptop can
# reach it over the homelab subnet/Tailscale jump; bind_guard in
# api_server.py:3372 already refuses non-localhost binds without a
# real key, so the same vault entry is doing the auth gating.
#
# Endpoints:
#   POST /v1/runs              — submit a new agent run, returns run_id
#   GET  /v1/runs/{run_id}     — poll status
#   GET  /v1/runs/{run_id}/events — SSE event stream (start/tool_call/end)
#   POST /v1/runs/{run_id}/stop — kill an in-flight run
#
# Rotate via:
#   ansible-vault edit group_vars/all/vault.yml  # update vault_hermes_gw_api_server_key
#   ansible-playbook -i inventory deploy_hermes_gateway.yml  # re-render env block + Restart Hermes Gateway
API_SERVER_KEY={{ vault_hermes_gw_api_server_key }}
# Bound on loopback because `tailscale serve` (configured by the
# hermes_gateway role) terminates HTTPS on :443 of the LXC's tailnet
# interface and proxies to http://127.0.0.1:8642. External access goes
# https://hermes-gw-01.tail19c543.ts.net → tailscale serve → here.
# The bind_guard in api_server.py:3372 still requires API_SERVER_KEY
# even on 127.0.0.1 because the in-process discord adapter calls
# `Bearer <key>` either way.
API_SERVER_HOST=127.0.0.1

# Phase-7 multi-principal auth. api_server reads this YAML file at
# startup and treats it as {principal_name: bearer_token}. A matching
# token resolves the request's principal for audit-log attribution and
# per-principal revocation. Legacy API_SERVER_KEY above still works in
# parallel (matches as principal `default`); rotating a single
# principal is a vault edit + playbook re-run — nothing else.
API_SERVER_KEYS_FILE=/etc/hermes-gateway/api_keys.yaml

# Audit log path. /v1/runs POST appends a JSON line per submission
# with (ts, event, run_id, principal, prompt_sha256, remote). Empty
# disables. Rotated daily, kept 30 days; see audit_logrotate.j2.
API_SERVER_AUDIT_LOG=/var/log/hermes-gateway/audit.log

# Bearer token the in-process discord adapter sends when calling the
# api_server on 127.0.0.1:8642. Distinct from the laptop's key so the
# audit log shows `discord-adapter` as the principal for /submit slash
# commands; rotation of either side doesn't take the other down.
# Falls back to API_SERVER_KEY in the adapter code when unset.
HERMES_DISCORD_API_KEY={{ vault_hermes_gw_api_key_discord_adapter }}
