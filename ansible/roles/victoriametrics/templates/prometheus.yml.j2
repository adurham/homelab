global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'homeassistant'
    metrics_path: /api/prometheus
    scheme: http
    static_configs:
      - targets: ['192.168.86.2:8123']
    bearer_token: "{{ homeassistant_token }}"

  # node_exporter-shape metrics:
  #   - All Alloy hosts push to VM via prometheus.remote_write — no scrape
  #     entries needed.
  #   - tanium_cluster (TanOS appliances) is the only pull-target group;
  #     they run a hardened :9100 install via roles/tanium_node_exporter.
  - job_name: 'node_exporter'
    static_configs:
{# Tanium zone servers (tzs-*) excluded for now -- ansible can't reach them
   from the work MacBook via the personal MacBook jump path, so node_exporter
   isn't deployed there yet. Once connectivity is sorted, drop the
   `not in groups['tanium_zones']` filter. #}
{% for host in groups['tanium_cluster'] | default([]) %}
{% if hostvars[host].ansible_host is defined and host not in groups['tanium_zones'] %}
      - targets: ['{{ hostvars[host].ansible_host }}:9100']
        labels:
          hostname: '{{ host }}'
          instance: '{{ host }}'
          env: 'homelab'
          tanium_role: '{{ "server" if host in groups["tanium_servers"] else "module" if host in groups["tanium_modules"] else "client" }}'
{% endif %}
{% endfor %}

    relabel_configs:
      - source_labels: [hostname]
        regex: '(.+)'
        target_label: instance
        replacement: '$1'

  # ---------------------------------------------------------------------
  # Loki's own metrics. Loki exposes /metrics on the same port (3100) it
  # uses for the push API. Lets us alert on Loki's internal health
  # (ingestion errors, write failures) before logs stop flowing.
  # ---------------------------------------------------------------------
  - job_name: 'loki'
    static_configs:
      - targets: ['127.0.0.1:3100']
        labels:
          instance: 'vm-01'

  # ---------------------------------------------------------------------
  # Blackbox-driven probes (Tanium postgres reachability + cert expiry)
  # blackbox_exporter runs alongside victoria-metrics-prod on this host.
  # ---------------------------------------------------------------------

  # TCP probes to Tanium postgres ports. Server appliances run the TS
  # postgres on 5432; module servers run the TMS postgres on 5433.
  # `probe_success == 0` means: host down, postgres down, iptables wrong,
  # or tanium-postgres-lab-trust unit failed — all of which we want to know.
  - job_name: 'blackbox_tanium_postgres'
    metrics_path: /probe
    params:
      module: [tcp_connect]
    static_configs:
{% for host in groups['tanium_servers'] | default([]) %}
      - targets: ['{{ hostvars[host].ansible_host }}:5432']
        labels:
          instance: '{{ host }}'
          tanium_role: 'server'
{% endfor %}
{% for host in groups['tanium_modules'] | default([]) %}
      - targets: ['{{ hostvars[host].ansible_host }}:5433']
        labels:
          instance: '{{ host }}'
          tanium_role: 'module'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: target
      - target_label: __address__
        replacement: 127.0.0.1:9115

  # TCP probe to Tanium SERVER consoles on port 443. Catches "appliance up +
  # postgres up + httpd or Tanium services crashed" — a failure the
  # postgres-only probe (5432) misses. Module and zone servers don't expose
  # a console on 443, so they're not probed here (verified empirically — only
  # tanium_servers respond on 443).
  - job_name: 'blackbox_tanium_console'
    metrics_path: /probe
    params:
      module: [tcp_connect]
    static_configs:
{% for host in groups['tanium_servers'] | default([]) %}
      - targets: ['{{ hostvars[host].ansible_host }}:443']
        labels:
          instance: '{{ host }}'
          tanium_role: 'server'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: target
      - target_label: __address__
        replacement: 127.0.0.1:9115

  # HTTPS probes to public-facing services. probe_ssl_earliest_cert_expiry
  # is exposed automatically; we alert when it gets close to now().
  # Targets come from blackbox_https_targets (roles/victoriametrics/defaults).
  - job_name: 'blackbox_https_cert'
    metrics_path: /probe
    params:
      module: [https_2xx]
    static_configs:
      - targets:
{% for url in blackbox_https_targets | default([]) %}
          - {{ url }}
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: 127.0.0.1:9115
