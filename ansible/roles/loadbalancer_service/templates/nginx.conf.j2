# Don't leak the nginx version in `Server:` headers or default error pages.
server_tokens off;

# Defense-in-depth security headers reused across every TLS server block.
# CSP is intentionally narrow — only frame-ancestors, since stricter CSPs
# break the proxied apps' inline scripts/styles (Tanium console, Grafana,
# Authentik, Proxmox WebUI all use them).
#
# Two flavours:
#   security_headers            — strict DENY / 'none'. Use for apps that
#                                  do NOT iframe their own UI (whoami, auth,
#                                  grafana, victoriametrics).
#   security_headers_self_frame — SAMEORIGIN / 'self'. Use for apps whose own
#                                  UI uses a same-origin iframe sub-pane
#                                  (Proxmox Console tab, Tanium console).
#                                  Still blocks cross-origin clickjacking.
#
# If you change the default, smoke-test the Proxmox Console tab and the
# Tanium server console — header regressions there fail silently in the
# browser (white pane, 200 OK in nginx logs).
{% set security_headers %}
    add_header X-Frame-Options                "DENY" always;
    add_header X-Content-Type-Options         "nosniff" always;
    add_header Referrer-Policy                "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy        "frame-ancestors 'none'" always;
{% endset %}

{% set security_headers_self_frame %}
    add_header X-Frame-Options                "SAMEORIGIN" always;
    add_header X-Content-Type-Options         "nosniff" always;
    add_header Referrer-Policy                "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy        "frame-ancestors 'self'" always;
{% endset %}

# ACL: Define Internal Networks
geo $is_internal {
    default 0;
    {{ net_lan_range }} 1;  # LAN
    {{ net_private_range }}   1;  # Private VLAN
    100.64.0.0/10   1;  # Tailscale
    127.0.0.0/8     1;  # Localhost
    ::1             1;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      "";
}

# least_conn (not ip_hash): the Tailscale subnet router does SNAT, so
# every Tailscale peer arrives at lb-01 with source {{ net_private_gw }}.
# Under ip_hash that pinned every Tailscale user to the same upstream
# node, starving the other two. Once a Proxmox session is established
# the cluster shares ticket/cookie state via pmxcfs, so per-request
# fan-out across nodes is safe for the steady-state UI/API.
#
# OIDC login is the exception: Proxmox keeps the CSRF state + PKCE
# verifier in per-pveproxy-worker memory between /access/openid/auth-url
# and /access/openid/login, and that state is NOT replicated. If the
# callback POST lands on a different node than the auth-url request,
# the login fails with "authentication failure (401)". We solve that
# below by routing the /access/openid/* endpoints to a dedicated
# upstream (proxmox_oidc) so the entire handshake stays on one node
# per client, while every other request keeps load-balancing across
# the cluster.
upstream proxmox_cluster {
    least_conn;
{% for node in groups['proxmox_nodes'] | sort %}
    server {{ hostvars[node].ansible_host }}:8006;
{% endfor %}

    keepalive 32;
}

# OIDC handshake — ip_hash gives us per-client stickiness across the
# whole handshake (the same client always lands on the same node, so
# the CSRF+PKCE state created in auth-url is present when openid/login
# fires). If a node goes down, nginx marks it as such via max_fails
# and ip_hash re-keys surviving clients to the remaining backends —
# the handshake stays on one node either way, so login keeps working.
#
# The "ip_hash + Tailscale-SNAT collapse" problem that drove us off
# ip_hash for proxmox_cluster does not apply here: OIDC traffic is
# trivial (a couple of POSTs per login), so even if every Tailscale
# user pins to the same node the load impact is negligible.
upstream proxmox_oidc {
    ip_hash;
{% for node in groups['proxmox_nodes'] | sort %}
    server {{ hostvars[node].ansible_host }}:8006 max_fails=2 fail_timeout=15s;
{% endfor %}

    keepalive 8;
}

# Tanium servers DO require sticky sessions (in-memory session state on
# each appliance); ip_hash is correct here. Tanium consoles are accessed
# only from LAN / a small set of internal hosts, not Tailscale, so the
# SNAT collapse doesn't apply.
upstream tanium_servers {
    ip_hash;
{% for node in groups['tanium_servers'] | sort %}
    server {{ hostvars[node].ansible_host }}:443 max_fails=3 fail_timeout=10s;
{% endfor %}
    keepalive 32;
}

server {
    listen 80;
    server_name tanium.chi.lab.amd-e.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name tanium.chi.lab.amd-e.com;

    ssl_certificate /etc/nginx/ssl/wildcard.fullchain.cer;
    ssl_certificate_key /etc/nginx/ssl/wildcard.key;

    # SSL Optimization
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_buffer_size 4k;

    # HSTS
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    # Tanium's UI iframes its own console pane same-origin, so DENY/'none' breaks it.
{{ security_headers_self_frame }}

    location / {
        proxy_pass https://tanium_servers;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Websocket Support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Tanium uses self-signed internal certs
        proxy_ssl_verify off;
    }
}

server {
    listen 80;
    server_name proxmox.chi.lab.amd-e.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2 fastopen=3;
    server_name proxmox.chi.lab.amd-e.com;

    # ACL: Block external access
    if ($is_internal = 0) {
        return 403;
    }

    ssl_certificate /etc/nginx/ssl/wildcard.fullchain.cer;
    ssl_certificate_key /etc/nginx/ssl/wildcard.key;

    # SSL Optimization
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_buffer_size 4k;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    # Proxmox WebUI iframes its noVNC/xtermjs Console pane same-origin, so DENY/'none' breaks it.
{{ security_headers_self_frame }}

    # Allow large uploads (ISOs)
    client_max_body_size 0;
    proxy_request_buffering off;

    # Extended timeouts for large file operations
    proxy_connect_timeout 3600s;
    proxy_send_timeout 3600s;
    proxy_read_timeout 3600s;

    # Proxy Configuration
    location = /redirect_oidc.html {
        alias /var/www/html/proxmox/redirect_oidc.html;
    }

    # OIDC handshake — pin to a single node so the CSRF state + PKCE
    # verifier created in auth-url is available when /openid/login fires
    # the back-channel token exchange. See proxmox_oidc upstream above
    # for the full rationale. The matching prefix covers both
    # /api2/extjs/access/openid/* and /api2/json/access/openid/*.
    location ~ ^/api2/(extjs|json)/access/openid/ {
        proxy_pass https://proxmox_oidc;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        proxy_ssl_verify off;
    }

    location / {
        proxy_pass https://proxmox_cluster;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Websocket Support (Critical for VNC)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Proxmox uses self-signed (or other) certs on backends
        proxy_ssl_verify off;
    }
}

server {
    listen 443 ssl http2;
    server_name whoami.chi.lab.amd-e.com;

    ssl_certificate /etc/nginx/ssl/wildcard.fullchain.cer;
    ssl_certificate_key /etc/nginx/ssl/wildcard.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
{{ security_headers }}

    # Authentik Forward Auth
    location / {
        auth_request /outpost.goauthentik.io/auth/nginx;
        error_page 401 = @goauthentik_proxy_signin;
        auth_request_set $auth_cookie $upstream_http_set_cookie;
        add_header Set-Cookie $auth_cookie;

        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /outpost.goauthentik.io {
        proxy_pass https://auth.chi.lab.amd-e.com/outpost.goauthentik.io;
        proxy_set_header Host auth.chi.lab.amd-e.com;
        proxy_set_header X-Original-URL $scheme://$http_host$request_uri;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Server $host;
    }

    location @goauthentik_proxy_signin {
        internal;
        add_header Set-Cookie $auth_cookie;
        return 302 /outpost.goauthentik.io/start?rd=$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name auth.chi.lab.amd-e.com;

    ssl_certificate /etc/nginx/ssl/wildcard.fullchain.cer;
    ssl_certificate_key /etc/nginx/ssl/wildcard.key;

    # SSL Optimization
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_buffer_size 4k;

    # OCSP Stapling
    ssl_stapling on;
    ssl_stapling_verify on;
    ssl_trusted_certificate /etc/nginx/ssl/wildcard.fullchain.cer;
    resolver 1.1.1.1 8.8.8.8 valid=300s;
    resolver_timeout 5s;

    # HSTS (Strict-Transport-Security)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
{{ security_headers }}

    # Compression
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;

    location / {
        proxy_pass https://{{ ip_authentik }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Server $host;

        # Authentik (internal) uses self-signed/internal certs
        proxy_ssl_verify off;

        # Keepalive Support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

