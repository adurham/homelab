######################################################################
##
## ddclient.conf configuration for No-IP
##
######################################################################
daemon=300              # check every 5 minutes
syslog=yes              # log update msgs to syslog
mail=root               # mail all msgs to root
mail-failure=root       # mail failed update msgs to root
pid=/var/run/ddclient.pid # record PID in file.
ssl=yes                 # use ssl-support.

##
## No-IP (www.no-ip.com)
##
protocol=noip
## Public-IP detection: api.ipify.org returns the bare IPv4 (robust). The old
## checkip.dyndns.com method intermittently returned "address NOT FOUND" and
## icanhazip can return IPv6 — ipify avoids both.
use=web, web=api.ipify.org
server=dynupdate.no-ip.com
login={{ noip_username }}
password={{ noip_password }}
{{ noip_hostname }}
