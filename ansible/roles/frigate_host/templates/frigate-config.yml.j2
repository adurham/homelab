# {{ ansible_managed }}
# Frigate config — single camera (cat_room), CPU detection.
#
# Stream path: HA go2rtc add-on (Nest WebRTC->RTSP) -> Frigate's bundled go2rtc
# holds it warm -> camera consumes the bundled go2rtc's MP4 HTTP output.
#
# WHY MP4-over-HTTP and not RTSP: the HA go2rtc RTSP output for a Nest WebRTC
# source drops the H264 SPS/PPS parameter sets, so ffmpeg can't decode it
# ("non-existing PPS 0 referenced" / "Could not find codec parameters ...
# unspecified size"). go2rtc's MP4 muxer (avc1) inserts the parameter sets
# inband, so ffmpeg decodes cleanly at native 1080p. Routing through Frigate's
# OWN bundled go2rtc keeps the producer warm, which removes the >20s cold-start
# that otherwise trips Frigate's 20s no-frames watchdog. Verified working
# 2026-05-31: camera_fps 5.0 sustained, 0 restarts/110s, CPU inference ~19ms.

mqtt:
{% if frigate_mqtt_enabled %}
  enabled: true
  host: {{ frigate_mqtt_host }}
  port: {{ frigate_mqtt_port }}
{% if frigate_mqtt_user %}
  user: {{ frigate_mqtt_user }}
  password: {{ frigate_mqtt_password }}
{% endif %}
{% else %}
  # No broker confirmed in the repo; see roles/frigate_host/defaults/main.yml.
  enabled: false
{% endif %}

go2rtc:
  streams:
    cat_room:
      - "{{ frigate_rtsp_source }}"

detectors:
  cpu1:
    type: cpu

cameras:
  cat_room:
    ffmpeg:
      inputs:
        # MP4-over-HTTP from the bundled go2rtc (localhost) — carries inband
        # SPS/PPS that the RTSP output drops. See header note.
        - path: "http://127.0.0.1:1984/api/stream.mp4?src=cat_room"
          input_args:
            - -f
            - mp4
          roles:
            - detect
            - record
    detect:
      enabled: true
      width: {{ frigate_detect_width }}
      height: {{ frigate_detect_height }}
      fps: {{ frigate_detect_fps }}
    objects:
      track:
{% for obj in frigate_track_objects %}
        - {{ obj }}
{% endfor %}
    record:
      enabled: true
      continuous:
        days: {{ frigate_record_retain_days }}
      motion:
        days: 0

version: 0.17-0
