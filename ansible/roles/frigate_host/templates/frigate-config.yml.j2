# {{ ansible_managed }}
# Frigate config — all Nest cameras, CPU detection.
#
# Stream path per camera: HA go2rtc add-on (Nest WebRTC->stream) -> Frigate
# camera consumes the HA go2rtc's MP4 HTTP output DIRECTLY.
#
# WHY MP4-over-HTTP, directly from the HA go2rtc (no Frigate-side go2rtc hop):
# the go2rtc RTSP output for a Nest WebRTC source drops the H264 SPS/PPS
# parameter sets, so ffmpeg can't decode it ("non-existing PPS" /
# "decode_slice_header error" / "unspecified size"). go2rtc's MP4 muxer (avc1)
# inserts the parameter sets inband, so ffmpeg decodes cleanly at native
# 1080p. An intermediate Frigate-side go2rtc RTSP restream RE-INTRODUCES the
# corruption (RTSP transport drops the params again) — so consume the HA MP4
# endpoint straight. Verified 2026-05-31.

mqtt:
{% if frigate_mqtt_enabled %}
  enabled: true
  host: {{ frigate_mqtt_host }}
  port: {{ frigate_mqtt_port }}
{% if frigate_mqtt_user %}
  user: {{ frigate_mqtt_user }}
  password: {{ frigate_mqtt_password }}
{% endif %}
{% else %}
  # No broker confirmed in the repo; see roles/frigate_host/defaults/main.yml.
  enabled: false
{% endif %}

detectors:
  cpu1:
    type: cpu

cameras:
{% for name, label in frigate_cameras.items() %}
  {{ name }}:
    friendly_name: "{{ label }}"
    ffmpeg:
      inputs:
        # MP4-over-HTTP straight from the HA go2rtc add-on — carries inband
        # SPS/PPS that the RTSP output drops. See header note.
        - path: "http://{{ frigate_go2rtc_host }}:1984/api/stream.mp4?src={{ name }}"
          input_args:
            - -f
            - mp4
          roles:
            # detect only — NO record role. Video footage lives in Nest/Google
            # Home (family already uses it); Frigate recording was a redundant
            # 50G disk + CPU hog. We keep detection + event snapshots only.
            - detect
    detect:
      enabled: true
      width: {{ frigate_detect_width }}
      height: {{ frigate_detect_height }}
      fps: {{ frigate_camera_fps[name] | default(frigate_detect_fps) }}
    objects:
      track:
{% for obj in frigate_track_objects %}
        - {{ obj }}
{% endfor %}
    record:
      enabled: false
    snapshots:
      # Keep a still image per detected person/cat event (tiny) so you can see
      # what triggered an alert. No video recording.
      enabled: true
      retain:
        default: {{ frigate_record_retain_days }}
{% endfor %}

version: 0.17-0
