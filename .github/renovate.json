{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "timezone": "America/Chicago",
  "prHourlyLimit": 4,
  "prConcurrentLimit": 6,
  "packageRules": [
    {
      "description": "Promtail was removed from Loki releases at v3.7.0 — Grafana is deprecating Promtail for Alloy. Renovate would 404 on every Promtail bump from now on. Disable tracking until we migrate. See docs/promtail-to-alloy-plan.md.",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["ansible/roles/promtail/defaults/main.yml"],
      "enabled": false
    },
    {
      "description": "Default reviewer / assignee for all renovate PRs",
      "matchManagers": ["custom.regex"],
      "assignees": ["adurham"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/roles/blackbox_exporter/defaults/main\\.yml$/"
      ],
      "matchStrings": ["blackbox_exporter_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "prometheus/blackbox_exporter",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/roles/common_monitoring/defaults/main\\.yml$/"
      ],
      "matchStrings": ["node_exporter_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "prometheus/node_exporter",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/roles/victoriametrics/defaults/main\\.yml$/"
      ],
      "matchStrings": ["victoriametrics_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "VictoriaMetrics/VictoriaMetrics",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/roles/loki/defaults/main\\.yml$/"
      ],
      "matchStrings": ["loki_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "grafana/loki",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/roles/promtail/defaults/main\\.yml$/"
      ],
      "matchStrings": ["promtail_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "grafana/loki",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/roles/grafana/defaults/main\\.yml$/"
      ],
      "matchStrings": ["go_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "golang/go",
      "extractVersionTemplate": "^go(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/roles/grafana/defaults/main\\.yml$/"
      ],
      "matchStrings": ["grafana_image_renderer_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "grafana/grafana-image-renderer"
    }
  ]
}
