exclude_paths:
  - ansible/group_vars/all/tanium_secrets.yml
  - ansible/credentials/
  - ansible/inventory/
  - homeassistant/
  - scripts/
  - .github/

skip_list:
  - fqcn
  - no-changed-when
  - var-naming
  - command-instead-of-module
  - command-instead-of-shell
  - yaml
  - name
  - ignore-errors
  - internal-error
