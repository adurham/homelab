# Home Assistant Secrets Template
# Copy this file to secrets.yaml and fill in your actual values
# secrets.yaml is gitignored and will not be committed

# Sony TV REST API pre-shared key (set under TV's Network -> Home Network Setup -> IP Control)
sony_tv_psk: "REPLACE_ME"

# Webhook ID for Grafana → HA alert forwarding. Must match the URL Grafana
# POSTs to (configured via ansible/inventory/group_vars/all.yml as a vaulted
# variable). Generate with: openssl rand -hex 32
grafana_alert_webhook_id: "REPLACE_ME"
